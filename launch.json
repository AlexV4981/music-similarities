{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "▶ Start Flask Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/app.py",
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": { "FLASK_ENV": "development", "FLASK_DEBUG": "0" }
        },
        {
            "name": "🎵 Index Library (full)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/indexer.py",
            "args": ["${input:musicDir}"],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "🔄 Index Library (--update)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/indexer.py",
            "args": ["${input:musicDir}", "--update"],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "🧹 Index Library (--clean)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/indexer.py",
            "args": ["${input:musicDir}", "--clean"],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "🔬 Test Extractor",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/extractor.py",
            "args": ["${input:audioFile}"],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ],
    "inputs": [
        {
            "id": "musicDir",
            "type": "promptString",
            "description": "Absolute path to your music folder",
            "default": "/home/user/Music"
        },
        {
            "id": "audioFile",
            "type": "promptString",
            "description": "Absolute path to a test audio file",
            "default": "/home/user/Music/test.mp3"
        }
    ]
}
